{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/pypa/cibuildwheel/blob/main/cibuildwheel/resources/cibuildwheel.schema.json",
  "$defs": {
    "inherit": {
      "enum": [
        "none",
        "prepend",
        "append"
      ],
      "default": "none",
      "description": "How to inherit the parent's value."
    },
    "enable": {
      "enum": [
        "cpython-prerelease",
        "graalpy",
        "pyodide-prerelease",
        "pypy",
        "pypy-eol"
      ]
    },
    "description": "A Python version or flavor to enable."
  },
  "additionalProperties": false,
  "description": "cibuildwheel's settings.",
  "type": "object",
  "properties": {
    "audit-command": {
      "description": "Execute a shell command to audit each wheel after it is repaired. Use {wheel} for each wheel path, or {abi3_wheel} to only audit abi3 wheels.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_AUDIT_COMMAND",
      "$comment": "Use a tool to check wheels before the end of the run (https://cibuildwheel.pypa.io/en/stable/options/#audit-command)"
    },
    "audit-requires": {
      "description": "Install Python dependencies for the audit step.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_AUDIT_REQUIRES",
      "$comment": "Install Python dependencies for the audit step (https://cibuildwheel.pypa.io/en/stable/options/#audit-requires)"
    },
    "archs": {
      "description": "Change the architectures built on your machine by default.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_ARCHS",
      "$comment": "Change the architectures built on your machine by default. (https://cibuildwheel.pypa.io/en/stable/options/#archs)"
    },
    "before-all": {
      "description": "Execute a shell command on the build system before any wheels are built.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_BEFORE_ALL",
      "$comment": "Execute a shell command on the build system before any wheels are built. (https://cibuildwheel.pypa.io/en/stable/options/#before-all)"
    },
    "before-build": {
      "description": "Execute a shell command preparing each wheel's build.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_BEFORE_BUILD",
      "$comment": "Execute a shell command preparing each wheel's build (https://cibuildwheel.pypa.io/en/stable/options/#before-build)"
    },
    "before-test": {
      "description": "Execute a shell command before testing each wheel.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_BEFORE_TEST",
      "$comment": "Execute a shell command before testing each wheel (https://cibuildwheel.pypa.io/en/stable/options/#before-test)"
    },
    "build": {
      "default": [
        "*"
      ],
      "description": "Choose the Python versions to build.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_BUILD",
      "$comment": "Choose the Python versions to build (https://cibuildwheel.pypa.io/en/stable/options/#build-skip)"
    },
    "build-frontend": {
      "default": "default",
      "description": "Set the tool to use to build, either \"build\" (default), \"build[uv]\", \"uv\", or \"pip\"",
      "oneOf": [
        {
          "enum": [
            "pip",
            "build",
            "build[uv]",
            "uv",
            "default"
          ]
        },
        {
          "type": "string",
          "pattern": "^pip; ?args:"
        },
        {
          "type": "string",
          "pattern": "^build; ?args:"
        },
        {
          "type": "string",
          "pattern": "^build\\[uv\\]; ?args:"
        },
        {
          "type": "string",
          "pattern": "^uv; ?args:"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "enum": [
                "pip",
                "build",
                "build[uv]",
                "uv"
              ]
            },
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      ],
      "title": "CIBW_BUILD_FRONTEND",
      "$comment": "Set the tool to use to build, either \"build\" (default), \"build\\[uv\\]\", or \"pip\" (https://cibuildwheel.pypa.io/en/stable/options/#build-frontend)"
    },
    "build-verbosity": {
      "type": "integer",
      "minimum": -3,
      "maximum": 3,
      "default": 0,
      "description": "Increase/decrease the output of pip wheel.",
      "title": "CIBW_BUILD_VERBOSITY",
      "$comment": "Increase/decrease the output of the build (https://cibuildwheel.pypa.io/en/stable/options/#build-verbosity)"
    },
    "config-settings": {
      "description": "Specify config-settings for the build backend.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            ".+": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ]
            }
          }
        }
      ],
      "title": "CIBW_CONFIG_SETTINGS",
      "$comment": "Specify config-settings for the build backend. (https://cibuildwheel.pypa.io/en/stable/options/#config-settings)"
    },
    "container-engine": {
      "oneOf": [
        {
          "enum": [
            "docker",
            "podman"
          ]
        },
        {
          "type": "string",
          "pattern": "^docker; ?(create_args|disable_host_mount):"
        },
        {
          "type": "string",
          "pattern": "^podman; ?(create_args|disable_host_mount):"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "enum": [
                "docker",
                "podman"
              ]
            },
            "create-args": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "disable-host-mount": {
              "type": "boolean"
            }
          }
        }
      ],
      "title": "CIBW_CONTAINER_ENGINE",
      "$comment": "Specify the container engine to use when building Linux wheels (https://cibuildwheel.pypa.io/en/stable/options/#container-engine)"
    },
    "dependency-versions": {
      "default": "pinned",
      "description": "Specify how cibuildwheel controls the versions of the tools it uses",
      "oneOf": [
        {
          "enum": [
            "pinned",
            "latest"
          ]
        },
        {
          "type": "string",
          "description": "Path to a file containing dependency versions, or inline package specifications, starting with \"packages:\"",
          "not": {
            "enum": [
              "pinned",
              "latest"
            ]
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "file": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "packages": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      ],
      "title": "CIBW_DEPENDENCY_VERSIONS",
      "$comment": "Control the versions of the tools cibuildwheel uses (https://cibuildwheel.pypa.io/en/stable/options/#dependency-versions)"
    },
    "enable": {
      "description": "Enable or disable certain builds.",
      "oneOf": [
        {
          "$ref": "#/$defs/enable"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/enable"
          }
        }
      ],
      "title": "CIBW_ENABLE",
      "$comment": "Enable building with extra categories of selectors present. (https://cibuildwheel.pypa.io/en/stable/options/#enable)"
    },
    "environment": {
      "description": "Set environment variables needed during the build.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            ".+": {
              "type": "string"
            }
          }
        }
      ],
      "title": "CIBW_ENVIRONMENT",
      "$comment": "Set environment variables (https://cibuildwheel.pypa.io/en/stable/options/#environment)"
    },
    "environment-pass": {
      "description": "Set environment variables on the host to pass-through to the container during the build.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_ENVIRONMENT_PASS",
      "$comment": "Set environment variables on the host to pass-through to the container. (https://cibuildwheel.pypa.io/en/stable/options/#environment-pass)"
    },
    "manylinux-aarch64-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MANYLINUX_AARCH64_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "manylinux-armv7l-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MANYLINUX_ARMV7L_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "manylinux-i686-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MANYLINUX_I686_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "manylinux-ppc64le-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MANYLINUX_PPC64LE_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "manylinux-pypy_aarch64-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MANYLINUX_PYPY_AARCH64_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "manylinux-pypy_i686-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MANYLINUX_PYPY_I686_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "manylinux-pypy_x86_64-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MANYLINUX_PYPY_X86_64_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "manylinux-riscv64-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MANYLINUX_RISCV64_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "manylinux-s390x-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MANYLINUX_S390X_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "manylinux-x86_64-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MANYLINUX_X86_64_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "musllinux-aarch64-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MUSLLINUX_AARCH64_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "musllinux-armv7l-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MUSLLINUX_ARMV7L_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "musllinux-i686-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MUSLLINUX_I686_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "musllinux-ppc64le-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MUSLLINUX_PPC64LE_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "musllinux-riscv64-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MUSLLINUX_RISCV64_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "musllinux-s390x-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MUSLLINUX_S390X_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "musllinux-x86_64-image": {
      "type": "string",
      "description": "Specify alternative manylinux / musllinux container images",
      "title": "CIBW_MUSLLINUX_X86_64_IMAGE",
      "$comment": "Specify manylinux / musllinux container images (https://cibuildwheel.pypa.io/en/stable/options/#linux-image)"
    },
    "xbuild-tools": {
      "description": "Binaries on the path that should be included in an isolated cross-build environment",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_XBUILD_TOOLS",
      "$comment": "Binaries on the path that should be included in an isolated cross-build environment. (https://cibuildwheel.pypa.io/en/stable/options/#xbuild-tools)"
    },
    "pyodide-version": {
      "type": "string",
      "description": "Specify the version of Pyodide to use",
      "title": "CIBW_PYODIDE_VERSION",
      "$comment": "Specify the Pyodide version to use for `pyodide` platform builds (https://cibuildwheel.pypa.io/en/stable/options/#pyodide-version)"
    },
    "repair-wheel-command": {
      "description": "Execute a shell command to repair each built wheel.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_REPAIR_WHEEL_COMMAND",
      "$comment": "Execute a shell command to repair each built wheel (https://cibuildwheel.pypa.io/en/stable/options/#repair-wheel-command)"
    },
    "skip": {
      "description": "Choose the Python versions to skip.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_SKIP",
      "$comment": "Choose the Python versions to build (https://cibuildwheel.pypa.io/en/stable/options/#build-skip)"
    },
    "test-command": {
      "description": "Execute a shell command to test each built wheel.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_TEST_COMMAND",
      "$comment": "The command to test each built wheel (https://cibuildwheel.pypa.io/en/stable/options/#test-command)"
    },
    "test-extras": {
      "description": "Install your wheel for testing using `extras_require`",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_TEST_EXTRAS",
      "$comment": "Install your wheel for testing using `extras_require` (https://cibuildwheel.pypa.io/en/stable/options/#test-extras)"
    },
    "test-sources": {
      "description": "Test files that are required by the test environment",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_TEST_SOURCES",
      "$comment": "Paths that are copied into the working directory of the tests (https://cibuildwheel.pypa.io/en/stable/options/#test-sources)"
    },
    "test-groups": {
      "description": "Install extra groups when testing",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_TEST_GROUPS",
      "$comment": "Specify test dependencies from your project's `dependency-groups` (https://cibuildwheel.pypa.io/en/stable/options/#test-groups)"
    },
    "test-requires": {
      "description": "Install Python dependencies before running the tests",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_TEST_REQUIRES",
      "$comment": "Install Python dependencies before running the tests (https://cibuildwheel.pypa.io/en/stable/options/#test-requires)"
    },
    "test-skip": {
      "description": "Skip running tests on some builds.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ],
      "title": "CIBW_TEST_SKIP",
      "$comment": "Skip running tests on some builds (https://cibuildwheel.pypa.io/en/stable/options/#test-skip)"
    },
    "test-environment": {
      "description": "Set environment variables for the test environment",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            ".+": {
              "type": "string"
            }
          }
        }
      ],
      "title": "CIBW_TEST_ENVIRONMENT",
      "$comment": "Set environment variables for the test environment (https://cibuildwheel.pypa.io/en/stable/options/#test-environment)"
    },
    "test-runtime": {
      "description": "Additional configuration for the test runner",
      "oneOf": [
        {
          "type": "string",
          "pattern": "^$"
        },
        {
          "type": "object",
          "additionalProperties": false
        },
        {
          "type": "string",
          "pattern": "args:"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "args"
          ],
          "properties": {
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      ],
      "title": "CIBW_TEST_RUNTIME",
      "$comment": "Controls how the tests will be executed. (https://cibuildwheel.pypa.io/en/stable/options/#test-runtime)"
    },
    "overrides": {
      "type": "array",
      "description": "An overrides array",
      "items": {
        "type": "object",
        "required": [
          "select"
        ],
        "minProperties": 2,
        "additionalProperties": false,
        "properties": {
          "select": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          },
          "inherit": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "audit-command": {
                "$ref": "#/$defs/inherit"
              },
              "audit-requires": {
                "$ref": "#/$defs/inherit"
              },
              "before-all": {
                "$ref": "#/$defs/inherit"
              },
              "before-build": {
                "$ref": "#/$defs/inherit"
              },
              "xbuild-tools": {
                "$ref": "#/$defs/inherit"
              },
              "before-test": {
                "$ref": "#/$defs/inherit"
              },
              "config-settings": {
                "$ref": "#/$defs/inherit"
              },
              "container-engine": {
                "$ref": "#/$defs/inherit"
              },
              "environment": {
                "$ref": "#/$defs/inherit"
              },
              "environment-pass": {
                "$ref": "#/$defs/inherit"
              },
              "repair-wheel-command": {
                "$ref": "#/$defs/inherit"
              },
              "test-command": {
                "$ref": "#/$defs/inherit"
              },
              "test-extras": {
                "$ref": "#/$defs/inherit"
              },
              "test-sources": {
                "$ref": "#/$defs/inherit"
              },
              "test-requires": {
                "$ref": "#/$defs/inherit"
              },
              "test-environment": {
                "$ref": "#/$defs/inherit"
              },
              "test-runtime": {
                "$ref": "#/$defs/inherit"
              }
            }
          },
          "audit-command": {
            "$ref": "#/properties/audit-command"
          },
          "audit-requires": {
            "$ref": "#/properties/audit-requires"
          },
          "before-all": {
            "$ref": "#/properties/before-all"
          },
          "before-build": {
            "$ref": "#/properties/before-build"
          },
          "before-test": {
            "$ref": "#/properties/before-test"
          },
          "build-frontend": {
            "$ref": "#/properties/build-frontend"
          },
          "build-verbosity": {
            "$ref": "#/properties/build-verbosity"
          },
          "config-settings": {
